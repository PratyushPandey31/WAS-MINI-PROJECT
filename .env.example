# =====================================================================
#  AuthGuard-MFA — Environment Variables Template
#  DO NOT commit a real .env file to version control.
#  In production, inject these via AWS Secrets Manager / Vault / K8s Secrets.
# =====================================================================

# Server Port (default: 3000)
PORT=3000

# JWT HMAC-SHA256 Signing Secret
# IMPORTANT: Replace with a cryptographically random 32+ character string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_YOUR_OWN_STRONG_SECRET_KEY_MINIMUM_256_BITS
