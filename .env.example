# =====================================================================
# AuthGuard-MFA Cloud Environment Variables Template
# In cloud deployments (AWS ECS, Kubernetes), do not check in active .env.
# Inject these values at runtime using AWS Secrets Manager or HashiCorp Vault.
# =====================================================================

# Server Port
PORT=3000

# JSON Web Token Private Signing Key
# WARNING: Change this key to a long random cryptographic string in production!
JWT_SECRET=super_secret_jwt_hmac_signing_key_for_compliance_verification
